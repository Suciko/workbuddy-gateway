# CodeBuddy2API 环境变量配置
# 复制此文件为 .env 并填入真实值:  cp .env.example .env
#
# 注意: .env 已被 .gitignore 忽略，不要提交到 Git！

# --- 服务器 ---
CODEBUDDY_HOST=127.0.0.1
CODEBUDDY_PORT=8001

# --- 访问密码 (API 鉴权用，强烈建议设置) ---
CODEBUDDY_PASSWORD=your_password_here

# --- API Key (手动指定，留空则自动获取) ---
CODEBUDDY_API_KEY=

# --- API 端点 (留空自动根据网络环境选择) ---
# 内网: https://copilot.tencent.com
# 外网: https://www.codebuddy.ai
CODEBUDDY_API_ENDPOINT=

# --- 网络环境: internal(内网/IOA) 或留空(外网) ---
CODEBUDDY_INTERNET_ENVIRONMENT=internal

# --- 认证模式: auto / token / password ---
CODEBUDDY_AUTH_MODE=auto

# --- 日志级别: DEBUG / INFO / WARNING / ERROR ---
CODEBUDDY_LOG_LEVEL=INFO

# --- 可用模型列表 (逗号分隔) ---
CODEBUDDY_MODELS=claude-4.0,claude-3.7,gpt-5,gpt-5-mini,gpt-5-nano,o4-mini,gemini-2.5-flash,gemini-2.5-pro,auto-chat

# --- 凭证轮换次数 ---
CODEBUDDY_ROTATION_COUNT=1

# --- 凭证目录 ---
CODEBUDDY_CREDS_DIR=.codebuddy_creds

# --- 优先级路由 (按套餐过期时间) ---
CODEBUDDY_PRIORITY_ROUTING=true

# --- 云端服务器 (local_proxy.js 用) ---
CLOUD_URL=http://你的服务器IP:8001
CLOUD_PASSWORD=你的云端密码
CLOUD_SSH_HOST=你的服务器IP
CLOUD_SSH_USER=root
CLOUD_SSH_KEY=C:\\Users\\你的用户名\\.ssh\\id_ed25519
CLOUD_PROJECT_DIR=/root/codebuddy2api
